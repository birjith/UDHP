# Frontend Environment Variables
# Copy this file to .env.local and fill in the actual values

# API Configuration
# For development: http://localhost:5000/api
# For production (Vercel): https://your-render-backend.onrender.com/api
VITE_API_URL=https://udhp.onrender.com/api

# Node Environment
# This is automatically set by Vite during build
# Values: development, production
# NODE_ENV=production

# Optional: Analytics and debugging
# VITE_DEBUG=false
# VITE_LOG_LEVEL=info
