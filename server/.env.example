# Backend Environment Variables
# Copy this file to .env and fill in the actual values

# Server Configuration
PORT=5000
NODE_ENV=production

# Database Configuration
# MongoDB Atlas Connection URI
# Example: mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://your-username:your-password@cluster-name.mongodb.net/database-name?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your-username:your-password@cluster-name.mongodb.net/database-name?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# CORS Configuration
# Frontend URL - set to your Vercel deployment URL
# This will be auto-set by Render if using render.yaml
FRONTEND_URL=https://your-app.vercel.app

# Email Configuration (Optional - if using Nodemailer)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password

# Other Configurations
# Add any other environment-specific configurations here
